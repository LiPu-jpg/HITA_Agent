<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ========================================== -->
    <!-- style 模块主题 - 统一为 Material 3          -->
    <!-- ========================================== -->
    <style name="AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
    </style>

    <!-- ========================================== -->
    <!-- 底部弹窗主题 (继承 app 模块)                -->
    <!-- ========================================== -->
    <style name="TransparentBottomSheetDialogTheme" parent="Theme.Material3.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/TransparentBottomSheetStyle</item>
    </style>

    <style name="TransparentBottomSheetStyle" parent="Widget.Material3.BottomSheet">
        <item name="android:background">@android:color/transparent</item>
        <item name="behavior_peekHeight">460dp</item>
    </style>

    <!-- ========================================== -->
    <!-- 对话框主题                                  -->
    <!-- ========================================== -->
    <style name="TransparentDialogTheme" parent="Theme.Material3.Light.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowTitleStyle">@null</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Dialog</item>
        <item name="android:windowSoftInputMode">stateUnspecified|adjustPan</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- ========================================== -->
    <!-- 无阴影底部弹窗                              -->
    <!-- ========================================== -->
    <style name="TransparentBottomSheetDialogNoShadow" parent="@android:style/Theme.Dialog">
        <item name="bottomSheetStyle">@style/TransparentBottomSheetStyle</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowTitleStyle">@null</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Dialog</item>
        <item name="android:windowSoftInputMode">stateUnspecified|adjustPan</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- ========================================== -->
    <!-- 水波纹样式 (统一命名)                       -->
    <!-- ========================================== -->
    <style name="ripplePrimarySmall">
        <item name="android:colorControlHighlight">?attr/colorPrimary</item>
        <item name="android:radius">16dp</item>
    </style>

    <style name="ripplePrimaryHuge">
        <item name="android:colorControlHighlight">?attr/colorPrimary</item>
        <item name="android:radius">56dp</item>
    </style>

    <style name="ripplePrimary">
        <item name="android:colorControlHighlight">?attr/colorPrimary</item>
        <item name="android:radius">24dp</item>
    </style>

    <style name="ripplePrimaryTiny">
        <item name="android:colorControlHighlight">?attr/colorPrimary</item>
        <item name="android:radius">12dp</item>
    </style>

    <style name="rippleControl">
        <item name="android:radius">24dp</item>
    </style>

    <style name="rippleWhite">
        <item name="android:colorControlHighlight">@android:color/white</item>
        <item name="android:radius">24dp</item>
    </style>

    <style name="rippleControlSmall">
        <item name="android:radius">16dp</item>
    </style>
</resources>
