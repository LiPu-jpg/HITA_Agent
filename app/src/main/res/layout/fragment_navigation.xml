<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:overScrollMode="never"
    app:behavior_overlapTop="0dp"
    app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ====== 用户卡片 ====== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/user_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_4"
            android:layout_marginTop="@dimen/space_2"
            android:layout_marginEnd="@dimen/space_4"
            android:layout_marginBottom="@dimen/space_2"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:cardCornerRadius="@dimen/corner_large"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/space_4">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/avatar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    android:transitionName="useravatar"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.HITA.Full" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginStart="@dimen/space_3"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/nickname"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:maxEms="20"
                        android:singleLine="true"
                        android:textAppearance="@style/TextAppearance.HITA.BodyLarge"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/username"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_1"
                        android:alpha="0.6"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:textAppearance="@style/TextAppearance.HITA.BodySmall" />
                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:tintMode="src_in"
                    app:srcCompat="@drawable/ic_baseline_keyboard_arrow_right_24"
                    app:tint="?attr/colorOnSurfaceVariant" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ====== 课表快捷入口（双卡片） ====== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:layout_marginBottom="@dimen/space_2"
            android:orientation="horizontal">

            <!-- 最近课表 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_recent_timetable"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_marginStart="@dimen/space_4"
                android:layout_marginEnd="@dimen/space_2"
                android:layout_weight="1"
                android:clickable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                app:cardCornerRadius="@dimen/corner_large"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/space_3"
                    android:paddingEnd="@dimen/space_3">

                    <ImageView
                        android:id="@+id/iconBG"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="@dimen/space_3"
                        android:background="@drawable/shape_circle"
                        android:backgroundTint="?attr/colorPrimaryContainer"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        app:srcCompat="@drawable/ic_nav_timetable"
                        app:tint="?attr/colorOnPrimaryContainer" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <com.limpu.hitax.ui.widgets.FocusTextView
                            android:id="@+id/recent_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="marquee"
                            android:marqueeRepeatLimit="marquee_forever"
                            android:singleLine="true"
                            android:text="@string/recent_timetable"
                            android:textAppearance="@style/TextAppearance.HITA.LabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <com.limpu.hitax.ui.widgets.FocusTextView
                            android:id="@+id/recent_subtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_1"
                            android:ellipsize="marquee"
                            android:marqueeRepeatLimit="marquee_forever"
                            android:singleLine="true"
                            android:text="@string/give_me_notification_permission"
                            android:textAppearance="@style/TextAppearance.HITA.BodyMedium"
                            android:textColor="?attr/colorOnSurface"
                            android:textStyle="normal" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 课表管理 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_timetable"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_marginStart="@dimen/space_2"
                android:layout_marginEnd="@dimen/space_4"
                android:layout_weight="1"
                android:clickable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                app:cardCornerRadius="@dimen/corner_large"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/space_3"
                    android:paddingEnd="@dimen/space_3">

                    <ImageView
                        android:id="@+id/icon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="@dimen/space_3"
                        android:background="@drawable/shape_circle"
                        android:backgroundTint="?attr/colorPrimaryContainer"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        app:srcCompat="@drawable/ic_list"
                        app:tint="?attr/colorOnPrimaryContainer" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <com.limpu.hitax.ui.widgets.FocusTextView
                            android:id="@+id/timetable_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="marquee"
                            android:marqueeRepeatLimit="marquee_forever"
                            android:singleLine="true"
                            android:text="@string/title_timetable_manager"
                            android:textAppearance="@style/TextAppearance.HITA.LabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <com.limpu.hitax.ui.widgets.FocusTextView
                            android:id="@+id/timetable_subtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_1"
                            android:ellipsize="marquee"
                            android:marqueeRepeatLimit="marquee_forever"
                            android:singleLine="true"
                            android:text="@string/give_me_notification_permission"
                            android:textAppearance="@style/TextAppearance.HITA.BodyMedium"
                            android:textColor="?attr/colorOnSurface"
                            android:textStyle="normal" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ====== 课表工具 ====== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_4"
            android:layout_marginTop="@dimen/space_4"
            android:layout_marginEnd="@dimen/space_4"
            android:layout_marginBottom="@dimen/space_2"
            android:text="课表工具"
            android:textAppearance="@style/TextAppearance.HITA.TitleMedium"
            android:textColor="?attr/colorOnSurface" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_4"
            android:layout_marginEnd="@dimen/space_4"
            android:layout_marginBottom="@dimen/space_2"
            app:cardCornerRadius="@dimen/corner_large"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="@dimen/space_1"
                android:paddingBottom="@dimen/space_1">

                <!-- 导入课表 -->
                <LinearLayout
                    android:id="@+id/card_import"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/space_4"
                    android:paddingEnd="@dimen/space_4">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/shape_circle"
                        android:backgroundTint="?attr/colorPrimaryContainer"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        app:srcCompat="@drawable/ic_import"
                        app:tint="?attr/colorOnPrimaryContainer" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_3"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <com.limpu.hitax.ui.widgets.FocusTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:singleLine="true"
                            android:text="@string/import_timetable"
                            android:textAppearance="@style/TextAppearance.HITA.BodyMedium"
                            android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:tintMode="src_in"
                        app:srcCompat="@drawable/ic_baseline_keyboard_arrow_right_24"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_marginStart="@dimen/space_4"
                    android:layout_marginEnd="@dimen/space_4"
                    android:background="?attr/colorOutlineVariant" />

                <!-- ICS 导入 -->
                <LinearLayout
                    android:id="@+id/card_ics_import"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/space_4"
                    android:paddingEnd="@dimen/space_4">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/shape_circle"
                        android:backgroundTint="?attr/colorPrimaryContainer"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        app:srcCompat="@drawable/ic_baseline_cloud_download_24"
                        app:tint="?attr/colorOnPrimaryContainer" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_3"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <com.limpu.hitax.ui.widgets.FocusTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:singleLine="true"
                            android:text="导入 ICS 课表"
                            android:textAppearance="@style/TextAppearance.HITA.BodyMedium"
                            android:textColor="?attr/colorOnSurface" />

                        <com.limpu.hitax.ui.widgets.FocusTextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:singleLine="true"
                            android:text="从日历文件导入课程"
                            android:textAppearance="@style/TextAppearance.HITA.BodySmall"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:tintMode="src_in"
                        app:srcCompat="@drawable/ic_baseline_keyboard_arrow_right_24"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ====== 教务查询 ====== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_4"
            android:layout_marginTop="@dimen/space_4"
            android:layout_marginEnd="@dimen/space_4"
            android:layout_marginBottom="@dimen/space_2"
            android:text="@string/navi_jw_title"
            android:textAppearance="@style/TextAppearance.HITA.TitleMedium"
            android:textColor="?attr/colorOnSurface" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_4"
            android:layout_marginEnd="@dimen/space_4"
            android:layout_marginBottom="@dimen/space_2"
            app:cardCornerRadius="@dimen/corner_large"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="@dimen/space_1"
                android:paddingBottom="@dimen/space_1">

                <!-- 考试安排 -->
                <LinearLayout
                    android:id="@+id/card_subjects"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/space_4"
                    android:paddingEnd="@dimen/space_4">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/shape_circle"
                        android:backgroundTint="?attr/colorPrimaryContainer"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        app:srcCompat="@drawable/ic_baseline_today_24"
                        app:tint="?attr/colorOnPrimaryContainer" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_3"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <com.limpu.hitax.ui.widgets.FocusTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:singleLine="true"
                            android:text="@string/ade_exam"
                            android:textAppearance="@style/TextAppearance.HITA.BodyMedium"
                            android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:tintMode="src_in"
                        app:srcCompat="@drawable/ic_baseline_keyboard_arrow_right_24"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_marginStart="@dimen/space_4"
                    android:layout_marginEnd="@dimen/space_4"
                    android:background="?attr/colorOutlineVariant" />

                <!-- 成绩查询 -->
                <LinearLayout
                    android:id="@+id/card_scores"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/space_4"
                    android:paddingEnd="@dimen/space_4">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/shape_circle"
                        android:backgroundTint="?attr/colorPrimaryContainer"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        app:srcCompat="@drawable/ic_baseline_format_list_bulleted_24"
                        app:tint="?attr/colorOnPrimaryContainer" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_3"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <com.limpu.hitax.ui.widgets.FocusTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:singleLine="true"
                            android:text="@string/jw_tabs_cj"
                            android:textAppearance="@style/TextAppearance.HITA.BodyMedium"
                            android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:tintMode="src_in"
                        app:srcCompat="@drawable/ic_baseline_keyboard_arrow_right_24"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_marginStart="@dimen/space_4"
                    android:layout_marginEnd="@dimen/space_4"
                    android:background="?attr/colorOutlineVariant" />

                <!-- 空教室 -->
                <LinearLayout
                    android:id="@+id/card_empty_classroom"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/space_4"
                    android:paddingEnd="@dimen/space_4">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/shape_circle"
                        android:backgroundTint="?attr/colorPrimaryContainer"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        app:srcCompat="@drawable/ic_baseline_location_city_24"
                        app:tint="?attr/colorOnPrimaryContainer" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_3"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <com.limpu.hitax.ui.widgets.FocusTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:singleLine="true"
                            android:text="@string/shortcut_empty_classroom_short"
                            android:textAppearance="@style/TextAppearance.HITA.BodyMedium"
                            android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:tintMode="src_in"
                        app:srcCompat="@drawable/ic_baseline_keyboard_arrow_right_24"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ====== 课程资源 ====== -->
        <TextView
            android:id="@+id/textView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_4"
            android:layout_marginTop="@dimen/space_4"
            android:layout_marginEnd="@dimen/space_4"
            android:layout_marginBottom="@dimen/space_2"
            android:text="@string/navi_course_resource_title"
            android:textAppearance="@style/TextAppearance.HITA.TitleMedium"
            android:textColor="?attr/colorOnSurface" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_4"
            android:layout_marginEnd="@dimen/space_4"
            android:layout_marginBottom="@dimen/space_2"
            app:cardCornerRadius="@dimen/corner_large"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="@dimen/space_1"
                android:paddingBottom="@dimen/space_1">

                <!-- 课程查找 -->
                <LinearLayout
                    android:id="@+id/card_course_lookup"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/space_4"
                    android:paddingEnd="@dimen/space_4">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/shape_circle"
                        android:backgroundTint="?attr/colorPrimaryContainer"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        app:srcCompat="@drawable/ic_baseline_search_24"
                        app:tint="?attr/colorOnPrimaryContainer" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_3"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <com.limpu.hitax.ui.widgets.FocusTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:singleLine="true"
                            android:text="@string/navi_course_lookup"
                            android:textAppearance="@style/TextAppearance.HITA.BodyMedium"
                            android:textColor="?attr/colorOnSurface" />

                        <com.limpu.hitax.ui.widgets.FocusTextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:singleLine="true"
                            android:text="@string/navi_course_lookup_sub"
                            android:textAppearance="@style/TextAppearance.HITA.BodySmall"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:tintMode="src_in"
                        app:srcCompat="@drawable/ic_baseline_keyboard_arrow_right_24"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_marginStart="@dimen/space_4"
                    android:layout_marginEnd="@dimen/space_4"
                    android:background="?attr/colorOutlineVariant" />

                <!-- 提交 PR -->
                <LinearLayout
                    android:id="@+id/card_course_submit_pr"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/space_4"
                    android:paddingEnd="@dimen/space_4">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/shape_circle"
                        android:backgroundTint="?attr/colorPrimaryContainer"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        app:srcCompat="@drawable/ic_baseline_edit_24"
                        app:tint="?attr/colorOnPrimaryContainer" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_3"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <com.limpu.hitax.ui.widgets.FocusTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:singleLine="true"
                            android:text="@string/navi_course_submit_pr"
                            android:textAppearance="@style/TextAppearance.HITA.BodyMedium"
                            android:textColor="?attr/colorOnSurface" />

                        <com.limpu.hitax.ui.widgets.FocusTextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:singleLine="true"
                            android:text="@string/navi_course_submit_pr_sub"
                            android:textAppearance="@style/TextAppearance.HITA.BodySmall"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:tintMode="src_in"
                        app:srcCompat="@drawable/ic_baseline_keyboard_arrow_right_24"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ====== 设置 ====== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_4"
            android:layout_marginTop="@dimen/space_4"
            android:layout_marginEnd="@dimen/space_4"
            android:layout_marginBottom="@dimen/space_2"
            android:text="设置"
            android:textAppearance="@style/TextAppearance.HITA.TitleMedium"
            android:textColor="?attr/colorOnSurface" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_4"
            android:layout_marginEnd="@dimen/space_4"
            android:layout_marginBottom="@dimen/space_4"
            app:cardCornerRadius="@dimen/corner_large"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="@dimen/space_1"
                android:paddingBottom="@dimen/space_1">

                <!-- 课程提醒 -->
                <LinearLayout
                    android:id="@+id/card_course_reminder"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/space_4"
                    android:paddingEnd="@dimen/space_4">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/shape_circle"
                        android:backgroundTint="?attr/colorPrimaryContainer"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        app:srcCompat="@drawable/ic_baseline_access_alarm_24"
                        app:tint="?attr/colorOnPrimaryContainer" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_3"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <com.limpu.hitax.ui.widgets.FocusTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:singleLine="true"
                            android:text="课程提醒"
                            android:textAppearance="@style/TextAppearance.HITA.BodyMedium"
                            android:textColor="?attr/colorOnSurface" />

                        <com.limpu.hitax.ui.widgets.FocusTextView
                            android:id="@+id/course_reminder_subtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:singleLine="true"
                            android:text="上课前10分钟提醒"
                            android:textAppearance="@style/TextAppearance.HITA.BodySmall"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_course_reminder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
