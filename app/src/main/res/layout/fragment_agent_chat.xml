<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/backgroundColorBottom"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp">

        <Spinner
            android:id="@+id/sessionSpinner"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:spinnerMode="dialog" />

        <ImageView
            android:id="@+id/newSessionButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            android:src="@android:drawable/ic_menu_add"
            app:tint="?attr/textColorSecondary"
            android:contentDescription="新对话" />

        <ImageView
            android:id="@+id/deleteSessionButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="?attr/textColorSecondary"
            android:contentDescription="删除对话" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/messageList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:padding="8dp" />

    <TextView
        android:id="@+id/attachmentIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="4dp"
        android:textColor="?attr/textColorSecondary"
        android:textSize="12sp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/attachButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_upload"
            app:tint="?attr/textColorSecondary"
            android:contentDescription="@string/agent_chat_attach" />

        <EditText
            android:id="@+id/inputField"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="44dp"
            android:layout_weight="1"
            android:background="@drawable/bottom_sheet_rounded_background"
            android:backgroundTint="?attr/backgroundColorSecond"
            android:hint="@string/agent_chat_hint"
            android:imeOptions="actionSend"
            android:inputType="textCapSentences"
            android:maxLines="4"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="?attr/textColorPrimary"
            android:textColorHint="?attr/textColorSecondary"
            android:textSize="14sp"
            android:scrollbars="vertical" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/sendButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:contentDescription="@string/send"
            android:src="@android:drawable/ic_menu_send"
            app:backgroundTint="@color/cruel_summer_primary"
            app:fabCustomSize="44dp"
            app:tint="@color/white" />

    </LinearLayout>

</LinearLayout>
