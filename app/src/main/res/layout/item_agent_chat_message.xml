<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/space_3"
    android:paddingTop="@dimen/space_1"
    android:paddingEnd="@dimen/space_3"
    android:paddingBottom="@dimen/space_1">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/messageCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardElevation="2dp"
        app:cardMaxElevation="4dp"
        app:cardBackgroundColor="@android:color/white"
        app:strokeWidth="0dp">

        <LinearLayout
            android:id="@+id/messageContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/transparent">

            <LinearLayout
                android:id="@+id/thinkingIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingTop="@dimen/space_2"
                android:paddingEnd="10dp"
                android:paddingBottom="@dimen/space_2"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <ProgressBar
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:indeterminateTint="?attr/textColorSecondary"
                    android:indeterminateTintMode="src_atop" />

                <TextView
                    android:id="@+id/thinkingStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_2"
                    android:textSize="13sp"
                    android:textColor="?attr/textColorSecondary" />

            </LinearLayout>

            <TextView
                android:id="@+id/thinkingHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingTop="6dp"
                android:paddingEnd="10dp"
                android:textSize="12sp"
                android:textColor="?attr/textColorSecondary"
                android:visibility="gone" />

            <TextView
                android:id="@+id/thinkingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingBottom="6dp"
                android:maxWidth="280dp"
                android:textSize="12sp"
                android:textColor="?attr/textColorSecondary"
                android:visibility="gone" />

            <TextView
                android:id="@+id/messageText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="280dp"
                android:padding="10dp"
                android:textSize="14sp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
