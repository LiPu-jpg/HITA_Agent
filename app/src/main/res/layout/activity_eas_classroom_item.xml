<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/space_2"
    android:layout_marginTop="@dimen/space_2"
    android:layout_marginEnd="@dimen/space_2"
    android:layout_marginBottom="@dimen/space_2"
    android:clickable="true"
    android:foreground="?attr/selectableItemBackground"
    android:padding="@dimen/space_1"
    android:text="课程名称"
    android:textColor="?attr/textColorSecondary"
    android:textSize="12sp"
    app:cardBackgroundColor="?attr/backgroundColorSecond"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="@dimen/space_4"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1.3"
                android:maxEms="5"
                android:text="会计专业导论"
                android:textColor="?attr/textColorPrimary"
                android:textSize="16sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/state"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:background="@drawable/element_rounded_button_bg_primary_light"
            android:backgroundTint="?attr/backgroundColorBottomAsTint"
            android:backgroundTintMode="src_over"
            android:gravity="center"
            android:paddingLeft="@dimen/space_3"
            android:paddingTop="@dimen/space_1"
            android:paddingRight="@dimen/space_3"
            android:paddingBottom="@dimen/space_1"
            android:text="空闲"
            android:textColor="?attr/colorAccent"
            android:textStyle="bold" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
