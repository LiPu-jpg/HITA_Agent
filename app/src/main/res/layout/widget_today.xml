<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/widget_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/space_1"
        android:layout_marginBottom="@dimen/space_1"
        android:background="@drawable/widget_today_background"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="@dimen/space_4"
            android:paddingTop="@dimen/space_2"
            android:paddingEnd="@dimen/space_2">

            <LinearLayout
                android:id="@+id/wid"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/loading"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/logo"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_margin="@dimen/space_2"
                    android:background="@drawable/logo"
                    android:visibility="gone" />

            </LinearLayout>

            <FrameLayout
                android:id="@+id/refresh"
                android:layout_width="wrap_content"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/refresh_icon"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_margin="@dimen/space_3"
                    android:background="@drawable/widget_ic_refresh"
                    android:visibility="visible" />
            </FrameLayout>

        </LinearLayout>


        <ListView
            android:id="@+id/list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:divider="@android:color/transparent"
            android:gravity="center"
            android:visibility="gone">

        </ListView>

        <LinearLayout
            android:id="@+id/place_holder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingBottom="@dimen/space_4"
            android:visibility="visible">

            <ImageView
                android:id="@+id/loading_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:layout_marginStart="@dimen/space_4"
                android:layout_marginTop="@dimen/space_4"
                android:layout_marginEnd="@dimen/space_2"
                android:layout_marginBottom="@dimen/space_4"
                android:background="@drawable/widget_placeholder_timeline"
                android:visibility="gone" />

            <TextView
                android:id="@+id/loading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginEnd="@dimen/space_4"
                android:text="@string/widget_loading"
                android:textColor="@color/widget_text_secondary"
                android:textSize="19sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="1dp">

            <ImageView
                android:id="@+id/imageView13"
                android:layout_width="wrap_content"
                android:layout_height="5dp"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/space_1"
                android:layout_marginBottom="@dimen/space_2"
                android:layout_weight="1.6" />

            <ImageView
                android:id="@+id/imageView12"
                android:layout_width="wrap_content"
                android:layout_height="5dp"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/space_1"
                android:layout_marginBottom="@dimen/space_2"
                android:layout_weight="1"
                android:background="@drawable/widget_rounded_divider" />

            <ImageView
                android:id="@+id/imageView14"
                android:layout_width="wrap_content"
                android:layout_height="5dp"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/space_1"
                android:layout_marginBottom="@dimen/space_2"
                android:layout_weight="1.6" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
