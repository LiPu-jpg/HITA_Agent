<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/backgroundColorBottom">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:fitsSystemWindows="true"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapse"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            app:expandedTitleMargin="24dp"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:statusBarScrim="@android:color/transparent"
            app:title="@string/label_activity_exam_inquiry"
            app:toolbarId="@id/toolbar">


            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                app:contentInsetStart="0dp"
                app:contentInsetStartWithNavigation="0dp"
                app:layout_collapseMode="pin" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_gravity="bottom"
                android:layout_marginTop="@dimen/space_6"
                android:orientation="vertical"
                android:paddingStart="@dimen/space_6"
                android:paddingEnd="@dimen/space_6"
                android:paddingBottom="@dimen/space_4">

                <!-- 第一行：学期和考试类型选择器 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_3"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/exam_term_layout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:orientation="horizontal"
                        android:paddingTop="@dimen/space_2"
                        android:paddingBottom="@dimen/space_2">

                        <TextView
                            android:id="@+id/exam_term_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:maxEms="8"
                            android:ellipsize="end"
                            android:singleLine="true"
                            android:text="-"
                            android:textColor="?attr/textColorPrimary"
                            android:textSize="28sp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="36dp"
                            android:layout_gravity="center"
                            android:layout_marginStart="@dimen/space_1"
                            android:tintMode="src_in"
                            app:srcCompat="@drawable/ic_expand"
                            app:tint="?attr/colorPrimaryDisabled" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="@dimen/space_2"
                        android:layout_marginEnd="@dimen/space_2"
                        android:alpha="0.2"
                        android:background="?android:attr/dividerHorizontal" />

                    <LinearLayout
                        android:id="@+id/exam_type_layout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:orientation="horizontal"
                        android:paddingTop="@dimen/space_2"
                        android:paddingBottom="@dimen/space_2">

                        <TextView
                            android:id="@+id/exam_type_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:maxEms="8"
                            android:ellipsize="end"
                            android:singleLine="true"
                            android:text="-"
                            android:textColor="?attr/textColorPrimary"
                            android:textSize="28sp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="36dp"
                            android:layout_gravity="center"
                            android:layout_marginStart="@dimen/space_1"
                            android:tintMode="src_in"
                            app:srcCompat="@drawable/ic_expand"
                            app:tint="?attr/colorPrimaryDisabled" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 第二行：导入按钮 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:orientation="horizontal">

                    <br.com.simplepass.loadingbutton.customViews.CircularProgressButton
                        android:id="@+id/btn_import_all"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:background="@drawable/element_rounded_button_bg_primary"
                        android:text="@string/import_all_exams"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        app:finalCornerAngle="18dp"
                        app:initialCornerAngle="18dp"
                        app:spinning_bar_color="@color/white"
                        app:spinning_bar_padding="4dp"
                        app:spinning_bar_width="3dp" />
                </LinearLayout>
            </LinearLayout>

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/refresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never">

            <LinearLayout

                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/empty_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:layout_marginStart="@dimen/space_6"
                    android:layout_marginTop="@dimen/space_16"
                    android:layout_marginEnd="@dimen/space_6"
                    android:layout_marginBottom="@dimen/space_6"
                    android:alpha="0.8"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_gravity="center"
                        android:background="@drawable/element_round_primary_light"
                        android:padding="@dimen/space_6"
                        app:srcCompat="@drawable/ic_empty"
                        app:tint="?attr/colorPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="@dimen/space_3"
                        android:text="@string/exam_memo_hint" />
                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_4"
                    android:layout_marginTop="@dimen/space_2"
                    android:layout_marginEnd="@dimen/space_4"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    app:cardBackgroundColor="?attr/backgroundColorSecond"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/exam_structure"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:overScrollMode="never">

                    </androidx.recyclerview.widget.RecyclerView>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
