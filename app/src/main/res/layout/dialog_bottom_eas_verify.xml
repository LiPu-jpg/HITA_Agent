<?xml version="1.0" encoding="utf-8"?>


<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bottom_sheet_rounded_background"
    android:orientation="vertical"
    android:transitionName="card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/space_6"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/eas_verify_title"
                android:textColor="?attr/textColorPrimary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/title2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/hint_eas_login"
                android:textColor="?attr/textColorSecondary"
                android:textSize="16sp" />
        </LinearLayout>

        <br.com.simplepass.loadingbutton.customViews.CircularProgressButton
            android:id="@+id/button_login"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:layout_marginStart="@dimen/space_4"
            android:layout_marginEnd="@dimen/space_6"
            android:background="@drawable/element_rounded_button_bg_primary"
            android:text="@string/log_in"
            android:textColor="@color/white"
            android:textSize="18sp"
            app:finalCornerAngle="16dp"
            app:initialCornerAngle="16dp"
            app:spinning_bar_color="@color/white"
            app:spinning_bar_padding="5dp"
            app:spinning_bar_width="4dp" />
    </LinearLayout>

    <RadioGroup
        android:id="@+id/campus_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_4"
        android:layout_marginTop="@dimen/space_2"
        android:layout_marginEnd="@dimen/space_4"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/campus_shenzhen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/eas_campus_shenzhen" />

        <RadioButton
            android:id="@+id/campus_benbu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_3"
            android:text="@string/eas_campus_benbu" />

        <RadioButton
            android:id="@+id/campus_weihai"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_3"
            android:text="@string/eas_campus_weihai" />
    </RadioGroup>

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/username"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_4"
        android:layout_marginEnd="@dimen/space_4"
        android:background="@android:color/transparent"
        android:hint="@string/hint_eas_username"
        android:paddingLeft="@dimen/space_2"
        android:paddingTop="@dimen/space_4"
        android:paddingBottom="@dimen/space_4"
        android:singleLine="true" />

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/password"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_4"
        android:layout_marginEnd="@dimen/space_4"
        android:layout_marginBottom="@dimen/space_6"
        android:background="@android:color/transparent"
        android:hint="@string/hint_eas_password"
        android:inputType="textPassword"
        android:paddingLeft="@dimen/space_2"
        android:paddingTop="@dimen/space_4"
        android:paddingBottom="@dimen/space_4"
        android:singleLine="true" />

    <Button
        android:id="@+id/webview_login_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_4"
        android:layout_marginEnd="@dimen/space_4"
        android:layout_marginBottom="@dimen/space_6"
        android:text="@string/webview_login"
        android:visibility="gone"
        tools:visibility="gone" />

    <LinearLayout
        android:id="@+id/agreement_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_4"
        android:layout_marginEnd="@dimen/space_4"
        android:layout_marginBottom="@dimen/space_4"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <CheckBox
            android:id="@+id/agreement_checkbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="false" />

        <TextView
            android:id="@+id/agreement_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="?attr/textColorSecondary"
            android:textSize="12sp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</LinearLayout>


