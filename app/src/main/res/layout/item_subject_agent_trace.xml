<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/space_1"
    android:layout_marginTop="@dimen/space_1"
    android:layout_marginEnd="@dimen/space_1"
    android:layout_marginBottom="@dimen/space_1"
    android:background="@drawable/element_rounded_button_bg_white"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView
        android:id="@+id/trace_stage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="?attr/colorAccent"
        android:textSize="12sp"
        android:textStyle="bold"
        tools:text="tool_start" />

    <TextView
        android:id="@+id/trace_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="?attr/textColorPrimary"
        android:textSize="13sp"
        tools:text="Resolving candidates for subject" />

    <TextView
        android:id="@+id/trace_payload"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="?attr/textColorSecondary"
        android:textSize="11sp"
        tools:text="tool=resolve_course_candidates" />

    <TextView
        android:id="@+id/trace_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="end"
        android:textColor="?attr/textColorSecondary"
        android:textSize="10sp"
        tools:text="13:22:08" />

</LinearLayout>
